# Copy this file to .env.local and fill in real values.
# .env.local is gitignored — never commit real keys (Manifesto/Company Bible security principles).

# Supabase project settings > API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_ANON_PUBLIC_KEY

# Service-role key is NOT used anywhere in Phase 2. Do not add it to
# any NEXT_PUBLIC_ variable, ever — it bypasses Row Level Security.
# It will be introduced only when a future phase has a specific,
# server-only, justified need for it.
